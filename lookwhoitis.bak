<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Look Who It Is | Windrow Studio</title>
<meta name="description" content="A podcast where artists pull back the curtain on real music careers.">
<meta name="color-scheme" content="dark">

<style>
:root{
  --bg:#0b0e13;
  --card:#101722;
  --fg:#f3f6fb;
  --muted:#a1acb8;
  --line:rgba(255,255,255,.08);
  --accent:#12b76a;
}

*{box-sizing:border-box;margin:0;padding:0}

body{
  font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;
  background:radial-gradient(800px 400px at 50% -100px, rgba(18,183,106,.2), transparent 60%), var(--bg);
  color:var(--fg);
}

.wrap{
  max-width:1100px;
  margin:auto;
  padding:0 16px;
}

/* NAV */

header{
  border-bottom:1px solid var(--line);
  background:rgba(11,14,19,.85);
}

.nav{
  height:64px;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.brand{
  display:flex;
  align-items:center;
  gap:10px;
  font-weight:800;
}

.brand img{
  width:28px;
}

.dropdown{position:relative}

.hamburger{
  width:42px;height:42px;
  border-radius:10px;
  border:1px solid var(--line);
  background:rgba(255,255,255,.03);
  cursor:pointer;
}

.dropmenu{
  display:none;
  position:absolute;
  right:0;
  top:60px;
  background:var(--card);
  border:1px solid var(--line);
  border-radius:12px;
  padding:10px;
}

.dropmenu a{
  display:block;
  padding:10px;
  border-radius:8px;
  font-weight:700;
}

.dropmenu a:hover{
  background:rgba(255,255,255,.05);
}

.dropdown.open .dropmenu{display:block}

/* HERO */

.hero{
  padding:70px 0 40px;
  text-align:center;
}

.hero img{
  width:180px;
  margin-bottom:20px;
}

.hero h1{
  font-size:34px;
  margin-bottom:10px;
}

.hero p{
  color:var(--muted);
  max-width:600px;
  margin:auto;
}

/* BUTTONS */

.btn{
  display:inline-block;
  padding:12px 18px;
  border-radius:999px;
  border:1px solid var(--line);
  font-weight:700;
  margin-top:20px;
}

.btn.accent{
  background:var(--accent);
  color:#062612;
  border:none;
}

/* EPISODE CARD */

.tile{
  margin-top:40px;
  background:var(--card);
  border-radius:16px;
  border:1px solid var(--line);
  overflow:hidden;
}

.video-thumb img{
  width:100%;
  display:block;
}

.tile-copy{
  padding:20px;
}

.tile-copy h2{
  font-size:22px;
  margin-bottom:10px;
}

.tile-copy p{
  color:var(--muted);
  margin-bottom:15px;
}

.actions{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}

/* SECTION */

.section{
  padding:40px 0;
  text-align:center;
}

.section h2{
  margin-bottom:10px;
}

.section p{
  color:var(--muted);
  max-width:600px;
  margin:auto;
}

/* GRID */

.grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:16px;
  margin-top:20px;
}

.card{
  background:var(--card);
  border:1px solid var(--line);
  padding:18px;
  border-radius:12px;
}

.card p{color:var(--muted)}

/* FOOTER */

footer{
  border-top:1px solid var(--line);
  padding:20px 0;
  margin-top:40px;
  text-align:center;
  color:var(--muted);
}

@media(max-width:800px){
  .grid{grid-template-columns:1fr}
}
</style>
</head>

<body>

<header>
  <div class="wrap nav">
    <div class="brand">
      <img src="/windrow-logo.png">
      <span>Look Who It Is</span>
    </div>

    <div class="dropdown" id="nav">
      <button class="hamburger" onclick="toggleMenu()"></button>
      <div class="dropmenu">
        <a href="/">Home</a>
        <a href="/lookwhoitis.html">Podcast</a>
        <a href="/radio.html">Radio</a>
        <a href="/about.html">About</a>
        <a href="/contact.html">Contact</a>
        <a href="/guest/index.html">Guest Application</a>
      </div>
    </div>
  </div>
</header>

<main class="wrap">

<!-- HERO -->
<section class="hero">
  <img src="/lookwhowhite.png">
  <h1>Real music careers, not polished stories</h1>
  <p>Artists pull back the curtain on the years, setbacks, and decisions behind what actually lasts.</p>

  <a class="btn accent" href="https://youtu.be/CoeRpv1GdJk?si=EKKzuu_eOMmpNiiD" target="_blank">Watch Newest Episode</a>
</section>

<!-- NEWEST EPISODE -->
<div class="tile">
  <a class="video-thumb" href="https://youtu.be/CoeRpv1GdJk?si=EKKzuu_eOMmpNiiD" target="_blank">
    <img src="/kendalleugene.png" alt="Kendall Eugene episode thumbnail">
  </a>

  <div class="tile-copy">
    <h2>Kendall Eugene: Starting Over and Writing From Real Life</h2>
    <p>
      Kendall talks about losing everything, getting discovered through an Instagram cover,
      and building a music career by writing from real life and grinding it out on the road.
    </p>

    <div class="actions">
      <a class="btn accent" href="https://youtu.be/CoeRpv1GdJk?si=EKKzuu_eOMmpNiiD" target="_blank">Watch</a>
      <a class="btn" href="https://open.spotify.com/episode/76mMhjvpzRpm5yKoPN3lQl?si=42d5bb1b36524a8d" target="_blank">Listen</a>
    </div>
  </div>
</div>

<!-- WHY -->
<section class="section">
  <h2>Why this show exists</h2>
  <p>
    Most interviews stay surface level. This one focuses on the work, the setbacks,
    and what actually goes into building a career that lasts.
  </p>

  <div class="grid">
    <div class="card">
      <strong>No promo fluff</strong>
      <p>Real conversations instead of repeating press releases.</p>
    </div>

    <div class="card">
      <strong>Career reality</strong>
      <p>What actually happens behind the scenes over years.</p>
    </div>

    <div class="card">
      <strong>Built for listeners</strong>
      <p>For people who want more than surface-level music talk.</p>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  © <span id="year"></span> Windrow Studio
</footer>

</main>

<script>
function toggleMenu(){
  document.getElementById("nav").classList.toggle("open");
}

document.getElementById("year").textContent = new Date().getFullYear();
</script>

</body>
</html>
